{
  "name": "@landrop/server",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:receiver": "tsx watch src/server.ts --open",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "receiver": "node dist/server.js --open",
    "test": "vitest run"
  },
  "dependencies": {
    "@landrop/shared": "1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "mime-types": "^3.0.1",
    "multer": "^2.0.2",
    "ws": "^8.18.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.6.2",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "vitest": "^3.2.4"
  }
}
